<Window x:Class="Discovery.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Discovery"
        Topmost="True" ResizeMode="NoResize" Height="126" Width="251" WindowStyle="ToolWindow" Background="{DynamicResource {x:Static SystemColors.DesktopBrushKey}}">
    <Grid Margin="6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="48"/>
            <ColumnDefinition Width="26"/>
            <ColumnDefinition Width="54"/>
            <ColumnDefinition Width="26"/>
            <ColumnDefinition Width="70"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="42"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Text="Pilot"
                   Foreground="White"
                   VerticalAlignment="Center"
                   FontWeight="Bold" />
        <Button Grid.Row="0"
                Grid.Column="1"
                x:Name="PilotIndexDecreaseButton"
                Click="PilotIndexDecrease_Click"
                Content="-"
                FontWeight="Bold"
                Margin="0,0,3,0" />
        <TextBox Grid.Row="0"
                 Grid.Column="2"
                 x:Name="PilotIndexTextBox"
                 Text="1"
                 TextAlignment="Center"
                 VerticalContentAlignment="Center"
                 LostFocus="PilotIndexTextBox_LostFocus"
                 FontWeight="Bold"
                 IsEnabled="False" />
        <Button Grid.Row="0"
                Grid.Column="3"
                x:Name="PilotIndexIncreaseButton"
                Click="PilotIndexIncrease_Click"
                Content="+"
                FontWeight="Bold"
                Margin="3,0,0,0" />
        <Button Grid.Row="0"
                Grid.Column="4"
                x:Name="SamplesButton"
                Click="Samples_Click"
                Content="Samples"
                Background="#FF7F2CB4"
                FontWeight="Bold"
                Margin="8,0,0,0" />
        <Button Grid.Row="1"
                Grid.Column="0"
                x:Name="StartButton"
                Click="Automate_Click"
                Content="Start"
                Background="#FF2CB43A"
                FontWeight="Bold"
                Margin="0,8,0,0"
                Grid.ColumnSpan="5" />
    </Grid>
</Window>
